generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  hash      String
  trail     String
  line      String   @default("Default")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]
}

model Asset {
  id       String @id @default(uuid())
  filename String
  url      String
  hash     String
  postId   String
  post     Post   @relation(fields: [postId], references: [id])
}
